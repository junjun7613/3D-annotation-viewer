{
  "relationHierarchy": [
    {
      "id": "direct",
      "label": "Direct Relation",
      "description": "対象そのものに関する直接的証拠",
      "children": [
        {
          "id": "direct.bibliographic",
          "label": "Bibliographic Direct Relation",
          "resourceType": "bibliography",
          "children": [
            {
              "id": "biblio.mentions",
              "label": "mentions",
              "desc": "文献中で対象に言及している。",
              "examples": [
                "論文A ──mentions──▶ 土器A",
                "研究ノート ──mentions──▶ 石碑B"
              ]
            },
            {
              "id": "biblio.describes",
              "label": "describes",
              "desc": "対象について一定の詳細さをもって説明している。",
              "examples": [
                "遺跡報告書 ──describes──▶ 石碑A"
              ]
            },
            {
              "id": "biblio.reports",
              "label": "reports",
              "desc": "対象の発見・調査・出土等を一次的に報告する。",
              "examples": [
                "発掘報告書 ──reports──▶ 遺構B"
              ]
            },
            {
              "id": "biblio.analyzes",
              "label": "analyzes",
              "desc": "対象を研究主題として分析する。",
              "examples": [
                "研究論文 ──analyzes──▶ 仏像A"
              ]
            },
            {
              "id": "biblio.catalogues",
              "label": "catalogues",
              "desc": "対象を目録化・一覧化する。",
              "examples": [
                "収蔵品目録 ──catalogues──▶ 土器A"
              ]
            },
            {
              "id": "biblio.illustrates",
              "label": "illustrates",
              "desc": "対象の画像・図版・拓本等を掲載する。",
              "examples": [
                "図録 ──illustrates──▶ 石碑A"
              ]
            },
            {
              "id": "biblio.transcribes",
              "label": "transcribes",
              "desc": "対象に含まれる文字情報の翻刻を提供する。",
              "examples": [
                "碑文研究 ──transcribes──▶ 碑文A"
              ]
            },
            {
              "id": "biblio.translates",
              "label": "translates",
              "desc": "対象に含まれる文字情報の翻訳を提供する。",
              "examples": [
                "碑文研究 ──translates──▶ 碑文A"
              ]
            }
          ]
        },
        {
          "id": "direct.authority",
          "label": "Authority Direct Relation",
          "resourceType": "authority",
          "children": [
            {
              "id": "authority.identifies",
              "label": "identifies",
              "desc": "対象と典拠エンティティが実質的に同一である。",
              "examples": [
                "石碑画像 ──identifies──▶ Wikidata上の石碑個体",
                "仏像3Dモデル ──identifies──▶ 博物館収蔵品URI"
              ]
            },
            {
              "id": "authority.depicts",
              "label": "depicts",
              "desc": "対象が典拠エンティティを視覚的に表象している。",
              "examples": [
                "仏像 ──depicts──▶ 阿弥陀如来",
                "浮世絵 ──depicts──▶ 富士山",
                "図屏風 ──depicts──▶ 大坂の陣"
              ]
            },
            {
              "id": "authority.mentions",
              "label": "mentions",
              "desc": "対象中に典拠エンティティへの言及が存在する。",
              "examples": [
                "碑文 ──mentions──▶ 聖武天皇",
                "古文書 ──mentions──▶ 奈良",
                "銘文 ──mentions──▶ 東大寺"
              ]
            }
          ]
        },
        {
          "id": "direct.media",
          "label": "Media Direct Relation",
          "resourceType": "media",
          "children": [
            {
              "id": "media.depicts",
              "label": "depicts",
              "desc": "メディアが対象そのものを表象している。",
              "examples": [
                "写真 ──depicts──▶ 土器A",
                "3Dモデル ──depicts──▶ 石碑A"
              ]
            },
            {
              "id": "media.depicts_part",
              "label": "depicts_part",
              "desc": "メディアが対象の一部分のみを表象している。",
              "examples": [
                "拡大写真 ──depicts_part──▶ 碑文の文字部分",
                "写真 ──depicts_part──▶ 土器の口縁部"
              ]
            },
            {
              "id": "media.documents",
              "label": "documents",
              "desc": "対象を記録するために作成されたメディア。",
              "examples": [
                "調査写真 ──documents──▶ 遺物A",
                "発掘写真 ──documents──▶ 遺構B"
              ]
            },
            {
              "id": "media.measures",
              "label": "measures",
              "desc": "対象の計測結果を表すメディア。",
              "examples": [
                "SfMモデル ──measures──▶ 建築A",
                "点群データ ──measures──▶ 仏像B"
              ]
            },
            {
              "id": "media.reproduces",
              "label": "reproduces",
              "desc": "対象の複製・転写・写しを提供する。",
              "examples": [
                "拓本 ──reproduces──▶ 石碑A",
                "複製画像 ──reproduces──▶ 絵画B"
              ]
            },
            {
              "id": "media.illustrates",
              "label": "illustrates",
              "desc": "対象を図示する資料。",
              "examples": [
                "実測図 ──illustrates──▶ 土器A",
                "立面図 ──illustrates──▶ 建築B"
              ]
